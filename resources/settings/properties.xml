<?xml version="1.0"?>
<properties>
  <!-- Background Theme: 0=Schwarz (AMOLED), 1=Hell -->
  <property id="bg_theme" type="number">0</property>

  <!-- Time Style: 0=12h, 1=Military (24h) -->
  <property id="time_style" type="number">1</property>

  <!-- Top Slots: 0=Wetter, 1=Kalorien, 2=Schritte, 3=Stockwerke, 4=Aktivitätszeit -->
  <property id="top_left"  type="number">0</property>
  <property id="top_right" type="number">2</property>

  <!-- AOD Time Color: 0=Orange mit weißer Outline, 1=Schwarz mit weißer Outline -->
  <property id="aod_color" type="number">0</property>
</properties>
